# =====================================================================
#  OWL Honeypot — Canarytoken secrets (DO NOT COMMIT the real file)
#  Copy to canary.env, fill with YOUR tokens from canarytokens.org,
#  and the app/service will load them at runtime.
#
#  Create tokens at https://canarytokens.org/generate (email = where alerts go)
# =====================================================================

# AWS API key token (the [default] creds block canarytokens gives you)
CANARY_AWS_KEY=AKIA...your-token...
CANARY_AWS_SECRET=...your-token-secret...

# Web-bug / URL token (fires when the bait page is opened)
CANARY_WEBBUG=http://canarytokens.com/tags/.../post.jsp

# DNS token (fires when the hostname is resolved)
CANARY_DNS=xxxxxxxx.canarytokens.com
