# =====================================================================
#  Lulz Honeypot — Caddy reverse proxy (production)
#  Fronts the Python honeypot with automatic Let's Encrypt TLS +
#  the passthrough of the REAL client IP (so GeoIP + logs are accurate)
#  + hardened response headers (GatesOS-grade).
#
#  1) Point a domain's A record at this server's public IP.
#  2) Replace honeypot.example.com below with that domain.
#  3) caddy run --config Caddyfile   (or use the systemd service)
#  Caddy auto-provisions the TLS cert on first request.
# =====================================================================

honeypot.example.com {
	encode zstd gzip

	# --- Protect the raw attack-log export (/api/eve) with basic auth ---
	# Anyone can watch the live dashboard, but the raw EVE-JSON export is
	# sensitive. Generate a hash:  caddy hash-password --plaintext 'yourpass'
	# then paste it below and uncomment. (Leave commented = eve is public.)
	# basic_auth /api/eve {
	#     admin <PASTE_CADDY_HASH_HERE>
	# }

	# --- Rate limit: SHED app-layer floods before they hit Python ---
	# Requires the caddy-ratelimit plugin. Build once with:
	#   caddy add-package github.com/mholt/caddy-ratelimit
	# (or: xcaddy build --with github.com/mholt/caddy-ratelimit)
	# Then uncomment. 120 req/min/IP is generous for a honeypot UI; floods
	# above that get 429'd at the edge instead of drowning the app.
	# rate_limit {
	#     zone perip { key {remote_host}  events 120  window 1m }
	#     zone global { key static        events 3000 window 1m }
	# }
	#
	# For VOLUMETRIC (network) DDoS, rate-limiting here is not enough — turn on
	# Cloudflare "Under Attack Mode" (or your provider's DDoS protection).
	# ufw + fail2ban cover slow brute-force; this covers HTTP floods.

	# forward everything to the honeypot app on localhost:8096
	reverse_proxy 127.0.0.1:8096 {
		# pass the real visitor IP so the honeypot logs/geo are accurate
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}

	# never cache the live API (defeats CDN/proxy caching of the feed)
	@api path /api/*
	header @api Cache-Control "no-store"

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		-Server
	}
}

